@page "/admin/notifications/{id:int}"
@model Seaway.Notifications.AdminUI.Pages.DetailModel
@{
    ViewData["Title"] = Model.NotificationType?.DisplayName ?? "Not Found";
}

@if (Model.NotificationType is null)
{
    <p class="admin-empty">Notification type not found.</p>
}
else
{
    <div class="admin-page-header">
        <h1>@Model.NotificationType.DisplayName</h1>
        <code class="admin-typekey">@Model.NotificationType.TypeKey</code>
        <p>@Model.NotificationType.Description</p>
    </div>

    <h2>Subscriptions</h2>

    @if (!Model.NotificationType.Subscriptions.Any())
    {
        <p class="admin-empty">No subscriptions configured. Add one below.</p>
    }
    else
    {
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Channel</th>
                    <th>Recipient</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var sub in Model.NotificationType.Subscriptions)
                {
                    <tr class="@(sub.IsActive ? "" : "admin-row-inactive")">
                        <td><span class="admin-channel admin-channel-@sub.Channel.ToLower()">@sub.Channel</span></td>
                        <td>@sub.Recipient</td>
                        <td>@(sub.IsActive ? "Active" : "Inactive")</td>
                        <td class="admin-actions">
                            <form method="post" asp-page-handler="Toggle"
                                  asp-route-id="@Model.NotificationType.Id"
                                  asp-route-subscriptionId="@sub.Id"
                                  style="display:inline">
                                <button type="submit" class="admin-btn admin-btn-sm">
                                    @(sub.IsActive ? "Disable" : "Enable")
                                </button>
                            </form>
                            <form method="post" asp-page-handler="Remove"
                                  asp-route-id="@Model.NotificationType.Id"
                                  asp-route-subscriptionId="@sub.Id"
                                  style="display:inline"
                                  onsubmit="return confirm('Remove this subscription?')">
                                <button type="submit" class="admin-btn admin-btn-sm admin-btn-danger">
                                    Remove
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <h2>Add Subscription</h2>

    <form method="post" asp-page-handler="Add"
          asp-route-id="@Model.NotificationType.Id"
          class="admin-form">
        <div class="admin-form-row">
            <label>Channel</label>
            <select asp-for="NewChannel" class="admin-select">
                <option value="">— select —</option>
                <option value="Email">Email</option>
                <option value="Sms">SMS</option>
                <option value="Teams">Teams</option>
                <option value="Phone">Phone</option>
            </select>
        </div>
        <div class="admin-form-row">
            <label>Recipient</label>
            <input asp-for="NewRecipient" class="admin-input"
                   placeholder="email address, phone number, or webhook URL" />
        </div>
        <div class="admin-form-row">
            <button type="submit" class="admin-btn">Add Subscription</button>
        </div>
    </form>
}
